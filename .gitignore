# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Build artifacts (do not commit - EAS stores builds in cloud)
*.aab
*.apk
*.apks
builds/

# Native (excluded when using Prebuild/CNG)
android/
ios/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# Firebase credentials (contains sensitive API keys)
google-services.json
*-firebase-adminsdk-*.json
*service-account*.json
firebase-service-account*.json

# typescript
*.tsbuildinfo

# Cursor IDE workspace storage files (accidentally copied temp files)
**/c__Users_*_AppData_Roaming_Cursor_*


